<services>
  <!-- FIBR-0155 § 3.9 - version flows one-way: the git tag drives set_version,
       which writes the .spec and debian/changelog Version fields (never hand
       typed, obs_packaging INV-6). Services run mode="manual" (osc service
       manualrun) for the documented first-cut submit; CI auto-submit is a
       follow-up (§ 2). -->

  <!-- 1. Source checkout. During bring-up this tracks the default branch (main),
          which carries the packaging/obs tree the recipes reference;
          versionformat derives the version from the most recent tag. For a
          published release, pin revision to that release tag instead. -->
  <service name="obs_scm" mode="manual">
    <param name="scm">git</param>
    <param name="url">https://github.com/milnet01/finbreak.git</param>
    <param name="revision">main</param>
    <param name="match-tag">v*</param>
    <param name="versionformat">@PARENT_TAG@</param>
    <param name="versionrewrite-pattern">v(.*)</param>
    <param name="versionrewrite-replacement">\1</param>
    <param name="filename">finbreak</param>
  </service>

  <!-- 2. Compress the checkout into finbreak-{version}.tar (Source0). -->
  <service name="tar" mode="manual"/>
  <service name="recompress" mode="manual">
    <param name="file">finbreak-*.tar</param>
    <param name="compression">gz</param>
  </service>

  <!-- 3. Inject the version into finbreak.spec + debian/changelog. -->
  <service name="set_version" mode="manual"/>

  <!-- 4. Vendored wheels (Source1, offline build): regenerate with
          packaging/obs/vendor-wheels.sh on a glibc >= 2.34 host, then
          osc add vendor.tar.gz. That script and README.md carry the closure
          details (ofxparse is sdist-only, pre-built to a wheel). -->
</services>
