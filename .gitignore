# Common — language-agnostic baseline. Python dev-artefacts are in the
# "Python" section; financial data (local vaults / *.db), tooling caches, and
# packaging output (*.dmg / AppImage / Flatpak / build / dist) follow below
# (FIBR-0002).

# Python — bytecode caches and the local dev virtualenv (.venv is also
# allowlisted in .gitleaks.toml and excluded by bandit).
__pycache__/
*.py[cod]
.venv/

# Financial data / local vaults — the SQLCipher vault and any database, plus
# the SQLite runtime sidecars (-wal/-shm/-journal) a live vault writes next to
# it. Must never reach the public repo (security-model T6/A7; FIBR-0002).
*.db
*.sqlite
*.sqlite3
*.db-*
*.sqlite-*
*.sqlite3-*

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.audit_cache/

# Packaging / build output — PyInstaller (build/, dist/), setuptools metadata
# (*.egg-info/), and the platform installers: macOS .dmg, Linux AppImage,
# Flatpak bundle + its build tree (FIBR-0002 / FIBR-0015).
build/
dist/
*.egg-info/
*.dmg
*.AppImage
*.flatpak
.flatpak-builder/

# OS
.DS_Store
Thumbs.db
desktop.ini
*.bak
*.orig
*.rej

# Editor / IDE
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
.#*
\#*\#

# Secrets / local env
.env
.env.*
!.env.example

# Claude Code (local settings, history, allowlist — mostly personal).
# Drop the trailing slash so the negations below can re-include
# specific files; with `.claude/` git short-circuits at the
# directory and ignores the !.claude/foo lines.
.claude/*
# Team-shared Claude Code config that SHOULD be in version control:
!.claude/settings.json
!.claude/workflow.md

# Logs / runtime
*.log
*.pid
*.sock

# Coverage / sanitizers
*.gcda
*.gcno
*.gcov
coverage.*
.coverage
lcov.info

# Core dumps
core
core.*
*.core
vgcore.*

# Scratch
scratch/
tmp/
Screenshot_*.png
screenshot*.png
